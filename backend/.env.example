# Copy this file to .env and fill in real values.
# .env is loaded by docker-compose automatically (env_file: .env in the app service).
# Never commit .env to git.

# ── OpenAI (required for nutrition photo analysis and AI recommendations) ──
OPENAI_API_KEY=sk-...

# ── SendGrid (optional — email notifications) ──────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=BodyFuel

# ── Twilio (optional — SMS notifications) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ── APNs (optional — iOS push notifications) ───────────────────────────────
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_SANDBOX=true
